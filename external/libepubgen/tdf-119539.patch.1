diff -ur libepubgen.org/src/lib/EPUBGenerator.cpp libepubgen/src/lib/EPUBGenerator.cpp
--- libepubgen.org/src/lib/EPUBGenerator.cpp	2026-07-02 18:46:39.616796632 +0200
+++ libepubgen/src/lib/EPUBGenerator.cpp	2026-07-02 18:50:55.733580395 +0200
@@ -336,6 +336,29 @@
   sink.insertCharacters(language);
   sink.closeElement("dc:language");
 
+  const librevenge::RVNGPropertyListVector *coverImages = m_metadata.child("librevenge:cover-images");
+  if (coverImages)
+  {
+    int nCurrentCover = 0;
+    for (size_t i = 0; i < coverImages->count(); ++i)
+    {
+      librevenge::RVNGPropertyList const &propertyList = (*coverImages)[i];
+      if (propertyList["office:binary-data"] && propertyList["librevenge:mime-type"])
+      {
+        ++nCurrentCover;
+
+        std::string strCurrentCover = std::to_string(nCurrentCover);
+        strCurrentCover.insert(0, 4 - strCurrentCover.length(), '0');
+        std::string content = "cover" + strCurrentCover;
+        RVNGPropertyList metaAttrs;
+        metaAttrs.insert("content", content.c_str());
+        metaAttrs.insert("name", "cover");
+        sink.openElement("meta", metaAttrs);
+        sink.closeElement("meta");
+      }
+    }
+  }
+
   if (m_version >= 30)
   {
     RVNGString date;
